@{
    var dotnetVersion = System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription;
    var isModern = dotnetVersion.Contains(".NET 8");
    var frameworkLabel = isModern ? ".NET 8.0" : ".NET Core 3.1";
    var frameworkBadge = isModern ? "bg-success" : "bg-danger";
    var dbLabel = isModern ? "Aurora Serverless" : "RDS MySQL 8.0";
    var dbBadge = isModern ? "bg-success" : "bg-danger";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - OrchardLite CMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #232F3E;">
        <div class="container">
            <a class="navbar-brand text-white" href="/"><i class="fas fa-leaf" style="color: #FF9900;"></i> OrchardLite CMS</a>
            <div class="navbar-nav ms-auto">
                <span class="badge @frameworkBadge me-2"><i class="fas fa-code"></i> @frameworkLabel</span>
                <span class="badge @dbBadge"><i class="fas fa-database"></i> @dbLabel</span>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="mt-5 py-3" style="background-color: #F2F3F3;">
        <div class="container text-center">
            <small class="text-muted">
                OrchardLite CMS - Enterprise Content Management | 
                <i class="fas fa-code"></i> <span class="@(isModern ? "text-success" : "text-danger")">@frameworkLabel</span> | 
                <i class="fas fa-database"></i> <span class="@(isModern ? "text-success" : "text-danger")">@dbLabel</span>
            </small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
